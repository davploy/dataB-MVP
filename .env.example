# Copy to `.env` at this repo root. Used by datab-mvp-backend (Flask) and datab-mvp-frontend (Vite).

ANTHROPIC_API_KEY=

# Optional. Path relative to datab-mvp-backend/ (default: assets/schema.json).
# OUTPUT_SCHEMA=assets/schema.json

# Optional. Leave unset in local dev to use the Vite proxy in vite.config.js.
# VITE_API_BASE=http://localhost:5000
